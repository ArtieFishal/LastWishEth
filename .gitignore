# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example
!.env.sample
!.env.template

# local config and editor state
*.local
.vscode/
.idea/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# build caches and local platform output
.netlify
.turbo/
.cache/

# wallet, key, and secret material
*.key
*.p12
*.pfx
*.keystore
*.wallet
*.seed
*.mnemonic
keystore/
wallets/

# backups and generated mock/export output
*.backup
*.old
*.orig
*.rej
*.bak
*.tmp
*.temp
backups/
mock-output/
public/mock/

# Cursor IDE development files
.cursor/
