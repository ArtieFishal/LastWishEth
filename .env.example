# LastWishCrypto - Environment Variable Template
#
# Copy this file to `.env.local` for local development:
#     cp .env.example .env.local
#
# Then fill in the values you actually want to use locally.
# DO NOT commit `.env.local` (it is gitignored).
# DO NOT put real secrets in this file (it is committed to git).

# =====================================================================
# REQUIRED for production (Netlify deployment)
# =====================================================================

# Moralis API key
# Used by: app/api/portfolio/evm/route.ts (EVM asset discovery on
# Ethereum, Base, Arbitrum, Polygon, ApeChain).
# Without this, the EVM portfolio API returns a clean configuration
# error instead of crashing.
# Get one at: https://moralis.io
MORALIS_API_KEY=

# WalletConnect (Reown) project ID
# Used by: lib/wagmi.ts to build the WalletConnect connector.
# Without this, the wallet connect QR flow will not initialize
# and the UI will surface a "WalletConnect not configured" hint.
# Get one at: https://cloud.reown.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# =====================================================================
# OPTIONAL (improve features but not strictly required to run)
# =====================================================================

# Helius API key
# Used by: app/api/portfolio/solana/route.ts to upgrade Solana
# discovery (DAS / token balances). Falls back to public RPC if absent.
# Get one at: https://helius.dev
HELIUS_API_KEY=

# Solana RPC URL
# Used by: app/api/portfolio/solana/route.ts. Either of these works.
# If both are unset, the app falls back to https://api.mainnet-beta.solana.com.
NEXT_PUBLIC_SOLANA_RPC_URL=
SOLANA_RPC_URL=

# Unstoppable Domains API key
# Used for resolving Unstoppable handles. Optional.
UNSTOPPABLE_API_KEY=

# Payment receiver address
# Used by: app/api/invoice/create/route.ts and
# app/api/invoice/status/route.ts. Accepts either a 0x address
# or an ENS name (will be resolved on Ethereum mainnet).
# Defaults to the lastwish.eth resolved address if unset.
PAYMENT_RECEIVER_ADDRESS=
